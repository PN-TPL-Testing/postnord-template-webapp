# Keep the Docker build context small and the layer cache stable.
# Anything listed here is never sent to the daemon, so it cannot bust a
# cached layer or bloat the image.

# Version control / CI
.git
.github
.gitignore

# Node — reinstalled inside the frontend build stage via `npm ci`
frontend/node_modules
node_modules

# React build output — generated inside the frontend build stage and copied
# from there, never from the build context.
app/static

# Python caches and local virtualenvs
**/__pycache__
*.py[cod]
.venv
venv
env
ENV

# Test / lint / coverage artefacts (not copied into the image)
tests
.pytest_cache
.ruff_cache
.coverage
htmlcov

# Local env files — secrets come from Secrets Manager at runtime
.env
.env.*

# Editor / OS cruft
.idea
.vscode
*.swp
*.swo
.DS_Store
Thumbs.db

# Conductor workspace scratch dir
.context

# Docs (not needed in the image)
README.md
CLAUDE.md
